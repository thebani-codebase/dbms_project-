# ============================================================================
# ENVIRONMENT CONFIGURATION - Backend
# Copy this file to .env and fill in your actual values
# ============================================================================

# ============================================================================
# DATABASE CONFIGURATION (Oracle 21c)
# ============================================================================
DB_USER=scheme_admin
DB_PASSWORD=Secure@12345
DB_CONNECTION_STRING=localhost:1521/XEPDB1
DB_POOL_MIN=2
DB_POOL_MAX=10

# ============================================================================
# API CONFIGURATION
# ============================================================================
PORT=3000
NODE_ENV=development
NODE_DEBUG=
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8081

# ============================================================================
# OPENAI GPT-4 CONFIGURATION
# ============================================================================
# Get your API key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# ============================================================================
# GOOGLE CLOUD CONFIGURATION
# Download service account key from: https://console.cloud.google.com
# ============================================================================
GCP_PROJECT_ID=your-gcp-project-id
GCP_KEY_FILE=/path/to/gcp-service-account-key.json

# ============================================================================
# AUTHENTICATION & SECURITY
# ============================================================================
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRY=7d
BCRYPT_ROUNDS=10

# ============================================================================
# LOGGING
# ============================================================================
LOG_LEVEL=info
LOG_FILE=/var/log/government-schemes-api.log

# ============================================================================
# AWS CONFIGURATION (For later deployment)
# ============================================================================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_S3_BUCKET=government-schemes-documents

# ============================================================================
# CACHE CONFIGURATION (Redis)
# ============================================================================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=3600

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_VOICE_PIPELINE=true
ENABLE_LLM_FALLBACK=true
ENABLE_BULK_PROCESSING=false
VOICE_CONFIDENCE_THRESHOLD=0.85

# ============================================================================
# MONITORING & ANALYTICS
# ============================================================================
SENTRY_DSN=
ENABLE_SENTRY=false

# ============================================================================
# MOBILE APP CONFIGURATION
# ============================================================================
MOBILE_APP_VERSION=1.0.0
API_BASE_URL=http://localhost:3000/api/v1
